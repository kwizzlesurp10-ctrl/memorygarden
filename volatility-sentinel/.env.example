# CoinGecko coin ids (comma-separated): https://api.coingecko.com/api/v3/coins/list
COIN_IDS=bitcoin,ethereum
VS_CURRENCY=usd

# Polling interval (seconds). CoinGecko free tier: stay >= 30.
POLL_INTERVAL_SECONDS=60

# Intra-window volatility: alert when high-low swing as %% of average price exceeds this (see README).
VOLATILITY_THRESHOLD_PCT=2.5
WINDOW_MINUTES=15

# SQLite database file (relative to cwd or absolute)
DATABASE_PATH=data/sentinel.db

# Optional: Discord webhook URL for alerts (leave empty for console-only)
WEBHOOK_URL=

# Seconds before the same coin can alert again after a volatility spike
ALERT_COOLDOWN_SECONDS=300
