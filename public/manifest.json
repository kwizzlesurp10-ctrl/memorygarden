{
  "name": "MemoryGarden - Nurture Your Memories",
  "short_name": "MemoryGarden",
  "description": "A private, emotional digital garden where you plant and nurture personal memories through visual plant metaphors that grow over time",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f5f3ef",
  "theme_color": "#6a9175",
  "orientation": "any",
  "icons": [
    {
      "src": "/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+memorygarden",
      "url": "/handle?protocol=%s"
    },
    {
      "protocol": "web+plantmemory",
      "url": "/plant?data=%s"
    },
    {
      "protocol": "web+viewmemory",
      "url": "/memory?id=%s"
    }
  ],
  "categories": ["lifestyle", "personalization", "utilities"],
  "screenshots": [],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "photos",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
